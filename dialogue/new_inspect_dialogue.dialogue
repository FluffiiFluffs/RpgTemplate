using QuestManager
using Inventory
using Interact
using DM

~ trashcan1
if interact_node.item_here == true
	NARRATOR: The trashcan has a shiny apple inside.[do add_item("testhpheal", 20)] [do item_here_off()] [do play_parent_animation("open")] => END
if interact_node.item_here == false
	PLAYER: [#mood=sad] Looks like there's nothing in this trashcan but poop. [do play_parent_animation("open")] => END